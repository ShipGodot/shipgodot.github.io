{"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"categoryPathComponent":"table-of-contents","category":"ShipGodot","title":"Getting Started","role":"project"},"sections":[{"chapter":"Prerequisites","kind":"hero","backgroundImage":"account-check.svg","title":"Getting Started","image":"account-check.svg","content":[{"type":"paragraph","inlineContent":[{"text":"In this section, you’ll prepare everything required to get started with ShipGodot.","type":"text"},{"text":" ","type":"text"},{"text":"Once these steps are completed, you’ll be fully prepared to use the project and begin building your dream iOS game.","type":"text"}]}]},{"kind":"tasks","tasks":[{"title":"Preparing your Accounts","stepsSection":[{"anchor":"Create-an-Apple-Developer-Account","type":"heading","level":3,"text":"Create an Apple Developer Account"},{"runtimePreview":null,"type":"step","caption":[],"content":[{"inlineContent":[{"type":"text","text":"Visit Apple’s developer website, create an Apple ID (or sign in with your existing one), and follow the enrollment steps."},{"type":"text","text":"\n"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Note: Apple requires an annual membership fee of about $99 USD per year."}]}],"type":"paragraph"}],"media":"apple-developer-enroll.png","code":null},{"anchor":"Create-a-GitHub-Account","type":"heading","level":3,"text":"Create a GitHub Account"},{"runtimePreview":null,"type":"step","caption":[],"content":[{"inlineContent":[{"type":"text","text":"To access the ShipGodot iOS template and use the provided automated workflows, you’ll need a GitHub account."}],"type":"paragraph"}],"media":"github-signup.png","code":null},{"anchor":"Buy-Access-to-the-ShipGodot-iOS-repository","type":"heading","level":3,"text":"Buy Access to the ShipGodot iOS repository"},{"runtimePreview":null,"type":"step","caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Head to "},{"type":"reference","identifier":"https:\/\/shipgodot.com","isActive":true},{"type":"text","text":" and purchase access."}]}],"media":"shipgodot_01.png","code":null},{"runtimePreview":null,"type":"step","caption":[],"content":[{"inlineContent":[{"type":"text","text":"After a successful purchase, you’ll be redirected to the redeem page. Redeem your license and connect it with your GitHub account to unlock access."}],"type":"paragraph"}],"media":"shipgodot_02.png","code":null},{"runtimePreview":null,"type":"step","caption":[],"content":[{"inlineContent":[{"type":"text","text":"If everything went smoothly, you’ll land on the success page."}],"type":"paragraph"}],"media":"shipgodot_03.png","code":null},{"runtimePreview":null,"type":"step","caption":[],"content":[{"inlineContent":[{"text":"Check your email — you should find an invite to the private repository.","type":"text"}],"type":"paragraph"}],"media":"shipgodot_04.png","code":null}],"anchor":"Preparing-your-Accounts","contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Before using ShipGodot, you’ll need an Apple Developer account, a GitHub account, and to purchase access to the template. Once set up, you’ll be ready to start building your iOS game."}]}],"media":"account-check.svg","mediaPosition":"trailing"}]},{"title":"Create a Repository for Certificates and Provisioning Profiles","stepsSection":[{"caption":[],"content":[{"inlineContent":[{"text":"Log in to your GitHub account and navigate to the page for creating a new repository.","type":"text"}],"type":"paragraph"}],"runtimePreview":null,"type":"step","code":null,"media":"github-create-certs.png"},{"caption":[],"content":[{"inlineContent":[{"type":"text","text":"Give the repository a clear name."},{"type":"text","text":"\n"},{"type":"text","text":"(for example, "},{"type":"strong","inlineContent":[{"type":"text","text":"apple-developer-certificates"}]},{"type":"text","text":")"}],"type":"paragraph"}],"runtimePreview":null,"type":"step","code":null,"media":"github-create-certs-name.png"},{"caption":[],"content":[{"inlineContent":[{"type":"text","text":"Set the repository visibility to Private."}],"type":"paragraph"}],"runtimePreview":null,"type":"step","code":null,"media":"github-create-certs-visibility.png"},{"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"Leave the remaining settings at their default values.","type":"text"}]}],"runtimePreview":null,"type":"step","code":null,"media":"github-create-certs-rest.png"}],"anchor":"Create-a-Repository-for-Certificates-and-Provisioning-Profiles","contentSection":[{"content":[{"inlineContent":[{"type":"text","text":"To use the automated code signing system, you’ll need to create an empty private GitHub repository to store your certificates and provisioning profiles."},{"type":"text","text":" "},{"type":"text","text":"ShipGodot relies on Fastlane Match, which follows the best-practice approach outlined in "},{"type":"reference","identifier":"https:\/\/codesigning.guide","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Once this repository is set up, workflows can access it during the build process without you having to manage the files manually."}],"type":"paragraph"}],"mediaPosition":"trailing","kind":"contentAndMedia","media":"file-sign.svg"}]},{"title":"Storing Your Project Credentials","stepsSection":[],"anchor":"Storing-Your-Project-Credentials","contentSection":[{"content":[{"inlineContent":[{"type":"text","text":"Each time you set up a new project using ShipGodot iOS, you’ll need to provide several GitHub secrets such as Apple Developer API key,"},{"type":"text","text":" "},{"type":"text","text":"deploy key for the certificates repository, and other sensitive values."},{"type":"text","text":" "},{"type":"text","text":"To keep everything secure and easy to reuse, it’s best to store these credentials in a password manager—"},{"identifier":"https:\/\/www.passwordstore.org\/","type":"reference","isActive":true},{"type":"text","text":" works well for this."},{"type":"text","text":" "},{"type":"text","text":"Since many of these values will be reused across multiple projects and workflows,"},{"type":"text","text":" "},{"type":"text","text":"having them safely stored means you can quickly reference and paste them whenever"},{"type":"text","text":" "},{"type":"text","text":"you initialize a new game project."}],"type":"paragraph"}],"mediaPosition":"trailing","media":"lock-check.svg","kind":"contentAndMedia"}]}]},{"kind":"callToAction","featuredEyebrow":"Tutorial","abstract":[{"text":"In this chapter, you’ll gather and securely store various secrets—like API keys and deploy keys—that will be reused across all future projects using ShipGodot iOS.","type":"text"}],"title":"Setting Up Your Reusable Credentials","action":{"isActive":true,"identifier":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/reusable-credentials","overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"type":"reference","overridingTitle":"Get started"}}],"kind":"project","identifier":{"url":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/getting-started","interfaceLanguage":"swift"},"hierarchy":{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/table-of-contents","modules":[{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/table-of-contents\/Prerequisites","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/getting-started#Preparing-your-Accounts"},{"kind":"task","reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/getting-started#Create-a-Repository-for-Certificates-and-Provisioning-Profiles"},{"kind":"task","reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/getting-started#Storing-Your-Project-Credentials"}],"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/getting-started"}]},{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/table-of-contents\/Credentials","projects":[{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/