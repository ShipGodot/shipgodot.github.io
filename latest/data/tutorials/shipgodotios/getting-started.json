ks":[{"stepsSection":[{"type":"heading","level":3,"text":"Create an Apple Developer Account","anchor":"Create-an-Apple-Developer-Account"},{"type":"step","caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Visit Apple’s developer website, create an Apple ID (or sign in with your existing one), and follow the enrollment steps."},{"type":"text","text":"\n"},{"type":"emphasis","inlineContent":[{"text":"Note: Apple requires an annual membership fee of about $99 USD per year.","type":"text"}]}]}],"media":"apple-developer-enroll.png","code":null,"runtimePreview":null},{"type":"heading","level":3,"text":"Create a GitHub Account","anchor":"Create-a-GitHub-Account"},{"type":"step","caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To access the ShipGodot iOS template and use the provided automated workflows, you’ll need a GitHub account."}]}],"media":"github-signup.png","code":null,"runtimePreview":null},{"type":"heading","level":3,"text":"Buy Access to the ShipGodot iOS repository","anchor":"Buy-Access-to-the-ShipGodot-iOS-repository"},{"type":"step","caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Head to "},{"isActive":true,"type":"reference","identifier":"https:\/\/shipgodot.com"},{"type":"text","text":" and purchase access."}]}],"media":"shipgodot_01.png","code":null,"runtimePreview":null},{"type":"step","caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If you bought the Snapshot, extract the archive and set up your own template repository by following the README.md inside it."}]}],"media":"shipgodot_01.png","code":null,"runtimePreview":null},{"type":"step","caption":[],"content":[{"inlineContent":[{"type":"text","text":"After purchasing a subscription, you’ll be redirected to the redeem page. Redeem your license and connect it with your GitHub account to unlock repository access."}],"type":"paragraph"}],"media":"shipgodot_02.png","code":null,"runtimePreview":null},{"type":"step","caption":[],"content":[{"inlineContent":[{"text":"If everything went smoothly, you’ll land on the success page.","type":"text"}],"type":"paragraph"}],"media":"shipgodot_03.png","code":null,"runtimePreview":null},{"type":"step","caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Check your email — you should find an invite to the private repository."}]}],"media":"shipgodot_04.png","code":null,"runtimePreview":null}],"title":"Preparing your Accounts","contentSection":[{"content":[{"inlineContent":[{"text":"Before using ShipGodot, you’ll need an Apple Developer account, a GitHub account, and to purchase access to the template. Once set up, you’ll be ready to start building your iOS game.","type":"text"}],"type":"paragraph"}],"media":"account-check.svg","kind":"contentAndMedia","mediaPosition":"trailing"}],"anchor":"Preparing-your-Accounts"},{"stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"Log in to your GitHub account and navigate to the page for creating a new repository."}],"type":"paragraph"}],"media":"github-create-certs.png","caption":[],"runtimePreview":null,"type":"step","code":null},{"content":[{"inlineContent":[{"text":"Give the repository a clear name.","type":"text"},{"text":"\n","type":"text"},{"text":"(for example, ","type":"text"},{"inlineContent":[{"type":"text","text":"apple-developer-certificates"}],"type":"strong"},{"text":")","type":"text"}],"type":"paragraph"}],"media":"github-create-certs-name.png","caption":[],"runtimePreview":null,"type":"step","code":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Set the repository visibility to Private."}]}],"media":"github-create-certs-visibility.png","caption":[],"runtimePreview":null,"type":"step","code":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Leave the remaining settings at their default values."}]}],"media":"github-create-certs-rest.png","caption":[],"runtimePreview":null,"type":"step","code":null}],"title":"Create a Repository for Certificates and Provisioning Profiles","contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To use the automated code signing system, you’ll need to create an empty private GitHub repository to store your certificates and provisioning profiles."},{"type":"text","text":" "},{"type":"text","text":"ShipGodot relies on Fastlane Match, which follows the best-practice approach outlined in "},{"type":"reference","identifier":"https:\/\/codesigning.guide","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Once this repository is set up, workflows can access it during the build process without you having to manage the files manually."}]}],"media":"file-sign.svg","kind":"contentAndMedia","mediaPosition":"trailing"}],"anchor":"Create-a-Repository-for-Certificates-and-Provisioning-Profiles"},{"stepsSection":[],"title":"Storing Your Project Credentials","contentSection":[{"mediaPosition":"trailing","media":"lock-check.svg","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"Each time you set up a new project using ShipGodot iOS, you’ll need to provide several GitHub secrets such as Apple Developer API key,","type":"text"},{"text":" ","type":"text"},{"text":"deploy key for the certificates repository, and other sensitive values.","type":"text"},{"text":" ","type":"text"},{"text":"To keep everything secure and easy to reuse, it’s best to store these credentials in a password manager—","type":"text"},{"identifier":"https:\/\/www.passwordstore.org\/","type":"reference","isActive":true},{"text":" works well for this.","type":"text"},{"text":" ","type":"text"},{"text":"Since many of these values will be reused across multiple projects and workflows,","type":"text"},{"text":" ","type":"text"},{"text":"having them safely stored means you can quickly reference and paste them whenever","type":"text"},{"text":" ","type":"text"},{"text":"you initialize a new game project.","type":"text"}]}]}],"anchor":"Storing-Your-Project-Credentials"}]},{"featuredEyebrow":"Tutorial","kind":"callToAction","title":"Setting Up Your Reusable Credentials","action":{"type":"reference","identifier":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/reusable-credentials","isActive":true,"overridingTitle":"Get started","overridingTitleInlineContent":[{"text":"Get started","type":"text"}]},"abstract":[{"type":"text","text":"In this chapter, you’ll gather and securely store various secrets—like API keys and deploy keys—that will be reused across all future projects using ShipGodot iOS."}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/shipgodotios\/getting-started"]}],"references":{"doc://ShipGodotIOS/tutorials/table-of-contents/Credentials":{"title":"Credentials","abstract":[],"url":"\/tutorials\/table-of-contents\/credentials","kind":"article","type":"topic","identifier":"doc:\/\/ShipGodotIOS\/tutorials\/table-of-contents\/Credentials","role":"article"},"doc://ShipGodotIOS/tutorials/table-of-contents/Prerequisites":{"role":"article","identifier":"doc:\/\/ShipGodotIOS\/tutorials\/table-of-contents\/Prerequisites","type":"topic","title":"Prerequisites","url":"\/tutorials\/table-of-contents\/prerequisites","abstract":[],"kind":"article"},"doc://ShipGodotIOS/tutorials/ShipGodotIOS/testflight":{"abstract":[{"type":"text","text":"In this chapter, you’ll go through everything needed to get your first build live on TestFlight."},{"type":"text","text":" "},{"type":"text","text":"You’ll create your app on App Store Connect, configure all the required secrets in your deployment repository,"},{"type":"text","text":" "},{"type":"text","text":"generate the necessary certificates and provisioning profiles, and finally trigger the pipeline to build and upload your game automatically."}],"url":"\/tutorials\/shipgodotios\/testflight","identifier":"doc:\/\/ShipGodotI