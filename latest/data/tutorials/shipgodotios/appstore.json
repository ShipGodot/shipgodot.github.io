{"metadata":{"category":"ShipGodot","role":"project","categoryPathComponent":"table-of-contents","title":"Shipping Your Game to the App Store"},"sections":[{"kind":"hero","title":"Shipping Your Game to the App Store","chapter":"Shipping","content":[{"inlineContent":[{"type":"text","text":"In this chapter, you’ll go through the full cycle of deploying updates to your testers, and when the time feels right, publishing your game to the App Store for the world to play."}],"type":"paragraph"}]},{"tasks":[{"title":"Continuous Deployment to TestFlight","contentSection":[{"content":[{"inlineContent":[{"text":"In this section, you’ll go through the full cycle of making a change to your game and deploying it to TestFlight.","type":"text"},{"text":" ","type":"text"},{"text":"From this point on, this is all it takes to get a new build in front of your testers.","type":"text"}],"type":"paragraph"}],"kind":"contentAndMedia","media":"airplane-edit.svg","mediaPosition":"trailing"}],"stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"For the sake of this tutorial, let’s make a small change to the Multitouch Cubes demo by modifying the background color."}],"type":"paragraph"}],"type":"step","media":"cd_00.png","caption":[],"code":null,"runtimePreview":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Before anything else, increment the version number in "},{"inlineContent":[{"type":"text","text":"Project > Project Settings > Application > Config"}],"type":"strong"},{"type":"text","text":""},{"type":"text","text":"\n"},{"type":"text","text":"— every new build uploaded to TestFlight must have a higher version number than the previous one."}]}],"type":"step","media":"cd_01.png","caption":[],"code":null,"runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"If you’re using drag and drop, upload the changed files directly to the game directory on GitHub."}],"type":"paragraph"}],"type":"step","media":"cd_02.png","caption":[],"code":null,"runtimePreview":null},{"content":[{"inlineContent":[{"text":"If you’re using submodules, make sure to update the submodule reference in the deployment repository to point to the new commit.","type":"text"}],"type":"paragraph"}],"type":"step","media":null,"caption":[],"code":"cd_03.sh","runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"Open your deployment repository on GitHub and navigate to "},{"type":"strong","inlineContent":[{"type":"text","text":"Actions"}]},{"type":"text","text":"."}],"type":"paragraph"}],"type":"step","media":"cd_04.png","caption":[],"code":null,"runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"Select the "},{"type":"strong","inlineContent":[{"text":"Distribute to TestFlight","type":"text"}]},{"type":"text","text":" workflow from the "},{"type":"strong","inlineContent":[{"text":"All Workflows","type":"text"}]},{"type":"text","text":" menu."}],"type":"paragraph"}],"type":"step","media":"cd_06.png","caption":[],"code":null,"runtimePreview":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Select the Godot version you are using, then click "},{"type":"strong","inlineContent":[{"type":"text","text":"Run Workflow"}]},{"type":"text","text":"."},{"type":"text","text":"\n"},{"type":"strong","inlineContent":[{"type":"text","text":"Note:"}]},{"type":"text","text":" Only stable Godot releases are supported."}]}],"type":"step","media":"cd_07.png","caption":[],"code":null,"runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"Wait for all jobs to complete."}],"type":"paragraph"}],"type":"step","media":"cd_08.png","caption":[],"code":null,"runtimePreview":null},{"content":[{"type":"paragraph","inlineContent":[{"text":"The updated build should appear in the TestFlight app shortly after.","type":"text"}]}],"type":"step","media":"cd_09.png","caption":[],"code":null,"runtimePreview":null}],"anchor":"Continuous-Deployment-to-TestFlight"},{"title":"Publishing to the App Store","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"inlineContent":[{"text":"When your testing is complete and you have a build on TestFlight that you’re happy with, publishing it to the App Store is just a few steps away.","type":"text"}],"type":"paragraph"}],"media":"cash.svg"}],"stepsSection":[{"code":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Head to your app page on App Store Connect.","type":"text"}]}],"caption":[],"media":"appstore_00.png","runtimePreview":null,"type":"step"},{"code":null,"content":[{"inlineContent":[{"type":"text","text":"Scroll down to click "},{"type":"strong","inlineContent":[{"text":"Add Build","type":"text"}]},{"type":"text","text":"."}],"type":"paragraph"}],"caption":[],"media":"appstore_01.png","runtimePreview":null,"type":"step"},{"code":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Select the build you are satisfied with from your TestFlight builds."}]}],"caption":[],"media":"appstore_02.png","runtimePreview":null,"type":"step"},{"code":null,"content":[{"inlineContent":[{"type":"text","text":"Fill in all the required screenshots and descriptions, then click "},{"type":"strong","inlineContent":[{"text":"Add for Review","type":"text"}]},{"type":"text","text":" when your page feels ready."},{"type":"text","text":"\n"},{"type":"strong","inlineContent":[{"text":"Note:","type":"text"}]},{"type":"text","text":" The App Store review process can take up to a week."}],"type":"paragraph"}],"caption":[],"media":"appstore_03.png","runtimePreview":null,"type":"step"}],"anchor":"Publishing-to-the-App-Store"},{"title":"Congratulations!","contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Thank you for using ShipGodot — your game is now live on the App Store! We hope it’s the first of many. Good luck with your future projects, and happy shipping!","type":"text"}]}],"kind":"contentAndMedia","mediaPosition":"trailing","me