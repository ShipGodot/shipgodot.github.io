ent":[{"text":"Select the Godot version you are using, then click ","type":"text"},{"inlineContent":[{"type":"text","text":"Run Workflow"}],"type":"strong"},{"text":".","type":"text"},{"text":"\n","type":"text"},{"inlineContent":[{"type":"text","text":"Note:"}],"type":"strong"},{"text":" Only stable Godot releases are supported.","type":"text"}]}],"media":"cd_07.png","runtimePreview":null},{"type":"step","caption":[],"code":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Wait for all jobs to complete.","type":"text"}]}],"media":"cd_08.png","runtimePreview":null},{"type":"step","caption":[],"code":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The updated build should appear in the TestFlight app shortly after."}]}],"media":"cd_09.png","runtimePreview":null}],"contentSection":[{"media":"airplane-edit.svg","kind":"contentAndMedia","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In this section, you’ll go through the full cycle of making a change to your game and deploying it to TestFlight."},{"type":"text","text":" "},{"type":"text","text":"From this point on, this is all it takes to get a new build in front of your testers."}]}]}],"anchor":"Continuous-Deployment-to-TestFlight","title":"Continuous Deployment to TestFlight"},{"stepsSection":[{"runtimePreview":null,"media":"appstore_00.png","type":"step","caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Head to your app page on App Store Connect."}]}],"code":null},{"runtimePreview":null,"media":"appstore_01.png","type":"step","caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Scroll down to click "},{"inlineContent":[{"type":"text","text":"Add Build"}],"type":"strong"},{"type":"text","text":"."}]}],"code":null},{"runtimePreview":null,"media":"appstore_02.png","type":"step","caption":[],"content":[{"inlineContent":[{"text":"Select the build you are satisfied with 