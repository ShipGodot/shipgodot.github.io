port ETC2 ASTC","type":"text"}]},{"text":" to true.","type":"text"}],"type":"paragraph"}],"media":"project_config_02.png","code":null},{"runtimePreview":null,"caption":[],"type":"step","content":[{"inlineContent":[{"text":"Go to ","type":"text"},{"inlineContent":[{"text":"Application > Config","type":"text"}],"type":"strong"},{"text":" and set a version number using format of three period-separated integers.","type":"text"},{"text":" ","type":"text"},{"text":"For example 0.0.1. Each number represents ","type":"text"},{"inlineContent":[{"text":"Major","type":"text"}],"type":"strong"},{"text":", ","type":"text"},{"inlineContent":[{"type":"text","text":"Minor"}],"type":"strong"},{"text":", and ","type":"text"},{"inlineContent":[{"type":"text","text":"Patch"}],"type":"strong"},{"text":" respectively.","type":"text"},{"text":"\n","type":"text"},{"inlineContent":[{"type":"text","text":"Important:"}],"type":"strong"},{"text":" You’ll need to increment the version number every time you want to upload a new build.","type":"text"}],"type":"paragraph"}],"media":"project_config_03.png","code":null},{"runtimePreview":null,"caption":[],"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Navigate to "},{"type":"strong","inlineContent":[{"type":"text","text":"Project > Export"}]},{"type":"text","text":" and add an "},{"type":"strong","inlineContent":[{"text":"iOS","type":"text"}]},{"type":"text","text":" export preset."}]}],"media":"project_config_04.png","code":null},{"runtimePreview":null,"caption":[],"type":"step","content":[{"inlineContent":[{"text":"Set ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"App Store Team ID"}]},{"text":" to ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"DO NOT EDIT"}]},{"text":".","type":"text"}],"type":"paragraph"}],"media":"project_config_05.png","code":null},{"runtimePreview":null,"caption":[],"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Set ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Provisioning Profile Specifier Release"}]},{"text":" to ","type":"text"},{"type":"strong","inlineContent":[{"text":"DO NOT EDIT","type":"text"}]},{"text":".","type":"text"}]}],"media":"project_config_06.png","code":null},{"runtimePreview":null,"caption":[],"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Set ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Bundle Identifier"}]},{"text":" to ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"DO NOT EDIT"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Note:"}]},{"text":" The ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"DO NOT EDIT"}]},{"text":" values will be automatically replaced by the pipeline during the deployment workflow.","type":"text"}]}],"media":"project_config_07.png","code":null},{"runtimePreview":null,"caption":[],"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Set ","type":"text"},{"inlineContent":[{"type":"text","text":"Export Project Only"}],"type":"strong"},{"text":" to true.","type":"text"}]}],"media":"project_config_08.png","code":null}]},{"contentSection":[{"media":"source-repository-multiple.svg","content":[{"inlineContent":[{"type":"text","text":"In this section, you’ll create your own deployment repository from the shipgodot-ios template."},{"type":"text","text":" "},{"type":"text","text":"This repository will hold all the scripts and configuration needed to automatically build and deploy your game."}],"type":"paragraph"}],"mediaPosition":"trailing","kind":"contentAndMedia"}],"title":"Setting Up the Deployment Repository","anchor":"Setting-Up-the-Deployment-Repository","stepsSection":[{"code":null,"content":[{"inlineContent":[{"text":"Navigate to the ","type":"text"},{"inlineContent":[{"text":"shipgodot-ios","type":"text"}],"type":