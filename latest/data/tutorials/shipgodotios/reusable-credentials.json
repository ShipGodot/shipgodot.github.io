pe":"step"},{"caption":[],"media":"apple-step11.png","code":null,"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Download the key file."}]}],"type":"step"},{"caption":[],"media":null,"code":"apple-step12.p8","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Open the API key file in a text editor.","type":"text"}]}],"type":"step"},{"caption":[],"media":null,"code":"apple-step12e.p8","runtimePreview":null,"content":[{"inlineContent":[{"text":"Keep the ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"—–BEGIN PRIVATE KEY—–"}]},{"text":" and ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"—–END PRIVATE KEY—–"}]},{"text":" markers intact.","type":"text"}],"type":"paragraph"}],"type":"step"},{"caption":[],"media":null,"code":"apple-step13.p8","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add "},{"type":"strong","inlineContent":[{"type":"text","text":"\\n"}]},{"type":"text","text":" immediately after "},{"type":"strong","inlineContent":[{"type":"text","text":"—–BEGIN PRIVATE KEY—–"}]},{"type":"text","text":"."}]}],"type":"step"},{"caption":[],"media":null,"code":"apple-step14.p8","runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"Add "},{"type":"strong","inlineContent":[{"type":"text","text":"\\n"}]},{"type":"text","text":" immediately before "},{"type":"strong","inlineContent":[{"type":"text","text":"—–END PRIVATE KEY—–"}]},{"type":"text","text":"."}],"type":"paragraph"}],"type":"step"},{"caption":[],"media":null,"code":"apple-step15.p8","runtimePreview":null,"content":[{"inlineContent":[{"text":"Remove all line breaks so the key becomes one continuous string.","type":"text"}],"type":"paragraph"}],"type":"step"},{"caption":[],"media":null,"code":"apple-step15.p8","runtimePreview":null,"content":[{"inlineContent":[{"text":"Verify that your key matches the format shown in the example.","type":"text"}],"type":"paragraph"}],"type":"step"},{"caption":[],"media":"password-60.svg","code":null,"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Save the edited API key in your password manager as ","type":"text"},{"inlineContent":[{"type":"text","text":"APPLE_API_KEY"}],"type":"strong"},{"text":".","type":"text"},{"text":"\n","type":"text"},{"text":"Once saved, delete the ","type":"text"},{"inlineContent":[{"text":"AuthKey_XXXXXXXXXX.p8","type":"text"}],"type":"emphasis"},{"text":" file from your file system to keep it secure.","type":"text"}]}],"type":"step"},{"caption":[],"media":"password-60.svg","code":null,"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Before moving on, save the email address you use to log in to the Apple Developer Portal as "},{"type":"strong","inlineContent":[{"text":"APPLE_DEVELOPER_EMAIL","type":"text"}]},{"type":"text","text":" in your password manager."},{"type":"text","text":" "},{"type":"text","text":"This way, all the credentials you’ll need when setting up a new project will be in one place."}]}],"type":"step"}]},{"anchor":"GitHub-Certificates-Repository-Credentials","contentSection":[{"media":"github.svg","mediaPosition":"trailing","kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"Before the CI workflows can build and publish your game to the App Store, they need access to your "},{"type":"reference","isActive":true,"overridingTitleInlineContent":[{"text":"certificates repository","type":"text"}],"overridingTitle":"certificates repository","identifier":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/getting-started#Create-a-Repository-for-Certificates-and-Provisioning-Profiles"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"In this section, we’ll create a GitHub deploy key that allows the workflows to read and update your certificates and provisioning profiles."}],"type":"paragraph"}]}],"title":"GitHub Certificates Repository Credentials","stepsSection":[{"text":"CERT_REPO_KEY","type":"heading","level":3,"anchor":"CERTREPOKEY"},{"media":"github-step01.png","code":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"First, you’ll need to generate an SSH key pair.","type":"text"},{"text":" ","type":"text"},{"text":"Follow ","type":"text"},{"type":"reference","identifier":"https:\/\/docs.github.com\/en\/authentication\/connecting-to-github-with-ssh\/generating-a-new-ssh-key-and-adding-it-to-the-ssh-agent#generating-a-new-ssh-key","isActive":true},{"text":" for your platform to create one.","type":"text"},{"text":"\n","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Note"}]},{"text":": When you reach the step that prompts you for a passphrase, ","type":"text"},{"type":"strong","inlineContent":[{"text":"leave it empty","type":"text"}]},{"text":". The CI workflows won’t be able to use a password-protected key.","type":"text"}]}],"caption":[],"runtimePreview":null},{"media":null,"code":"cert_repo01.txt","type":"step","content":[{"inlineContent":[{"text":"Copy the contents of the private key file and save it in your password manager as ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"CERT_REPO_KEY"}]},{"text":".","type":"text"},{"text":"\n","type":"text"},{"text":"Once saved, delete the private key file from your file system to keep it secure.","type":"text"}],"type":"paragraph"}],"caption":[],"runtimePreview":null},{"media":"github-step02.png","code":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"On GitHub, navigate to the main page of the certificates repository."}],"type":"paragraph"}],"caption":[],"runtimePreview":null},{"media":"github-step03.png","code":null,"type":"step","content":[{"inlineContent":[{"text":"Under your repository name, click ⚙️Settings. If you cannot see the “Settings” tab, select the dropdown menu, then click Settings.","type":"text"}],"type":"paragraph"}],"caption":[],"runtimePreview":null},{"media":"github-step04.png","code":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"In the sidebar, click Deploy Keys.","type":"text"}]}],"caption":[],"runtimePreview":null},{"media":"github-step05.png","code":null,"type":"step","content":[{"inlineContent":[{"text":"Click Add deploy key","type":"text"}],"type":"paragraph"}],"caption":[],"runtimePreview":null},{"media":"github-step06.png","code":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"In the “Title” field, provide a title. (eg. “Godot Template Workflows”)"}],"type":"paragraph"}],"caption":[],"runtimePreview":null},{"media":"github-step07.png","code":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"In the “Key” field, paste the contents of your generated public key file (the one ending in "},{"type":"codeVoice","code":".pub"},{"type":"text","text":")."}],"type":"paragraph"}],"caption":[],"runtimePreview":null},{"media":"github-step08.png","code":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Select ","type":"text"},{"type":"strong","inlineContent":[{"text":"Allow write access","type":"text"}]},{"text":".","type":"text"}]}],"caption":[],"runtimePreview":null},{"media":"github-step09.png","code":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Click Add key.","type":"text"}]}],"caption":[],"runtimePreview":null},{"text":"CERT_REPO_PASSWORD \/ CERT_REPO_URL","type":"heading","level":3,"anchor":"CERTREPOPASSWORD--CERTREPOURL"},{"media":"github-step10.png","code":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Save your certificates repository URL as "},{"type":"strong","inlineContent":[{"type":"text","text":"CERT_REPO_URL"}]},{"type":"text","text":" in your password manager. You can find the URL on the repository’s main page."},{"type":"text","text":"\n"},{"type":"strong","inlineContent":[{"type":"text","text":"Note"}]},{"type":"text","text":": Make sure to use the SSH URL (starting with "},{"type":"emphasis","inlineContent":[{"text":"git@github.com:","type":"text"}]},{"type":"text","text":")"}]}],"caption":[],"runtimePreview":null},{"media":"password-60.svg","code":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"Finally, you’ll need to create an encryption password to protect your certificates and provisioning profiles."},{"type":"text","text":" "},{"type":"text","text":"We recommend using your password manager to generate a strong, random password and save it as "},{"type":"strong","inlineContent":[{"type":"text","text":"CERT_REPO_PASSWORD"}]},{"type":"text","text":"."}],"type":"paragraph"}],"caption":[],"runtimePreview":null}]},{"title":"Credentials Checklist","anchor":"Credentials-Checklist","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"By the end of this section, your password manager should contain the following values,"},{"type":"text","text":" "},{"type":"text","text":"ready to be copied into your repository secrets whenever you set up a new project."},{"type":"text","text":" "},{"type":"text","text":"While not all of these are strictly credentials, keeping them together in your password manager makes setup quick and convenient:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"APPLE_API_KEY","type":"text"}],"type":"strong"},{"type":"text","text":" – Your App Store Connect API private key"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"APPLE_API_ISSUER_ID","type":"text"}]},{"text":" – The issuer ID associated with your API key","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"APPLE_API_KEY_ID"}],"type":"strong"},{"text":" – The key ID for your API key","type":"