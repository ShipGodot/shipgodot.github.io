{"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"title":"Shipping Your Game to the App Store","category":"ShipGodot","categoryPathComponent":"table-of-contents","role":"project"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/shipgodotios\/appstore"]}],"sections":[{"title":"Shipping Your Game to the App Store","content":[{"inlineContent":[{"type":"text","text":"In this chapter, you’ll go through the full cycle of deploying updates to your testers, and when the time feels right, publishing your game to the App Store for the world to play."}],"type":"paragraph"}],"kind":"hero","chapter":"Shipping"},{"kind":"tasks","tasks":[{"title":"Continuous Deployment to TestFlight","contentSection":[{"content":[{"inlineContent":[{"type":"text","text":"In this section, you’ll go through the full cycle of making a change to your game and deploying it to TestFlight."},{"type":"text","text":" "},{"type":"text","text":"From this point on, this is all it takes to get a new build in front of your testers."}],"type":"paragraph"}],"kind":"contentAndMedia","mediaPosition":"trailing","media":"airplane-edit.svg"}],"stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"For the sake of this tutorial, let’s make a small change to the Multitouch Cubes demo by modifying the background color."}],"type":"paragraph"}],"type":"step","code":null,"runtimePreview":null,"media":"cd_00.png","caption":[]},{"content":[{"inlineContent":[{"text":"Before anything else, increment the version number in ","type":"text"},{"inlineContent":[{"text":"Project > Project Settings > Application > Config","type":"text"}],"type":"strong"},{"text":"","type":"text"},{"text":"\n","type":"text"},{"text":"— every new build uploaded to TestFlight must have a higher version number than the previous one.","type":"text"}],"type":"paragraph"}],"type":"step","code":null,"runtimePreview":null,"media":"cd_01.png","caption":[]},{"content":[{"inlineContent":[{"text":"If you’re using drag and drop, upload the changed files directly to the game directory on GitHub.","type":"text"}],"type":"paragraph"}],"type":"step","code":null,"runtimePreview":null,"media":"cd_02.png","caption":[]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If you’re using submodules, make sure to update the submodule reference in the deployment repository to point to the new commit."}]}],"type":"step","code":"cd_03.sh","runtimePreview":null,"media":null,"caption":[]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open your deployment repository on GitHub and navigate to "},{"type":"strong","inlineContent":[{"type":"text","text":"Actions"}]},{"type":"text","text":"."}]}],"type":"step","code":null,"runtimePreview":null,"media":"cd_04.png","caption":[]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Select the "},{"type":"strong","inlineContent":[{"text":"Distribute to TestFlight","type":"text"}]},{"type":"text","text":" workflow from the "},{"type":"strong","inlineContent":[{"type":"text","text":"All Workflows"}]},{"type":"text","text":" menu."}]}],"type":"step","code":null,"runtimePreview":null,"media":"cd_06.png","caption":[]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Select the Godot version you are using, then click "},{"type":"strong","inlineContent":[{"text":"Run Workflow","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":"\n"},{"type":"strong","inlineContent":[{"type":"text","text":"Note:"}]},{"type":"text","text":" Only stable Godot releases are supported."}]}],"type":"step","code":null,"runtimePreview":null,"media":"cd_07.png","caption":[]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Wait for all jobs to complete.","type":"text"}]}],"type":"step","code":null,"runtimePreview":null,"media":"cd_08.png","caption":[]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The updated build should appear in the TestFlight app shortly after.","type":"text"}]}],"type":"step","code":null,"runtimePreview":null,"media":"cd_09.png","caption":[]}],"anchor":"Continuous-Deployment-to-TestFlight"},{"title":"Publishing to the App Store","contentSection":[{"media":"cash.svg","kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"When your testing is complete and you have a build on TestFlight that you’re happy with, publishing it to the App Store is just a few steps away."}],"type":"paragraph"}],"mediaPosition":"trailing"}],"stepsSection":[{"media":"appstore_00.png","code":null,"type":"step","content":[{"inlineContent":[{"text":"Head to your app page on App Store Connect.","type":"text"}],"type":"paragraph"}],"caption":[],"runtimePreview":null},{"media":"appstore_01.png","code":null,"type":"step","content":[{"inlineContent":[{"text":"Scroll down to click ","type":"text"},{"inlineContent":[{"text":"Add Build","type":"text"}],"type":"strong"},{"text":".","type":"text"}],"type":"paragraph"}],"caption":[],"runtimePreview":null},{"media":"appstore_02.png","code":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Select the build you are satisfied with from your TestFlight builds."}]}],"caption":[],"runtimePreview":null},{"media":"appstore_03.png","code":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"Fill in all the required screenshots and descriptions, then click "},{"type":"strong","inlineContent":[{"text":"Add for Review","type":"text"}]},{"type":"text","text":" when your page feels ready."},{"type":"text","text":"\n"},{"type":"strong","inlineContent":[{"type":"text","text":"Note:"}]},{"type":"text","text":" The App Store review process can take up to a week."}],"type":"paragraph"}],"caption":[],"runtimePreview":null}],"anchor":"Publishing-to-the-App-Store"},{"title":"Congratulations!","contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Thank you for using ShipGodot — your game is now live on the App Store! We hope it’s the first of many. Good luck with your future projects, and happy shipping!","type":"text"}]}],"mediaPosition":"trailing","media":"rocket.svg","kind":"contentAndMedia"}],"stepsSection":[],"anchor":"Congratulations"}]}],"hierarchy":{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/table-of-contents","paths":[["doc:\/\/ShipGodotIOS\/tutorials\/table-of-contents","doc:\/\/ShipGodotIOS\/tutorials\/table-of-contents\/$volume","doc:\/\/ShipGodotIOS\/tutorials\/table-of-contents\/Shipping"]],"modules":[{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/table-of-contents\/Prerequisites","projects":[{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/getting-started","sections":[{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/getting-started#Preparing-your-Accounts","kind":"task"},{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/getting-started#Create-a-Repository-for-Certificates-and-Provisioning-Profiles","kind":"task"},{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/getting-started#Storing-Your-Project-Credentials","kind":"task"}]}]},{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/table-of-contents\/Credentials","projects":[{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/reusable-credentials","sections":[{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/reusable-credentials#Apple-Developer-Credentials","kind":"task"},{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/reusable-credentials#GitHub-Certificates-Repository-Credentials","kind":"task"},{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/reusable-credentials#Credentials-Checklist","kind":"task"}]}]},{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/table-of-contents\/Project-Setup","projects":[{"sections":[{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/set-up#Getting-Your-Godot-Project-Ready","kind":"task"},{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/set-up#Setting-Up-the-Deployment-Repos