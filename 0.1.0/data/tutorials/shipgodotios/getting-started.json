":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Visit Apple’s developer website, create an Apple ID (or sign in with your existing one), and follow the enrollment steps."},{"type":"text","text":"\n"},{"type":"emphasis","inlineContent":[{"text":"Note: Apple requires an annual membership fee of about $99 USD per year.","type":"text"}]}]}],"caption":[],"media":"apple-developer-enroll.png","runtimePreview":null,"code":null},{"type":"heading","level":3,"text":"Create a GitHub Account","anchor":"Create-a-GitHub-Account"},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To access the ShipGodot iOS template and use the provided automated workflows, you’ll need a GitHub account."}]}],"caption":[],"media":"github-signup.png","runtimePreview":null,"code":null},{"type":"heading","level":3,"text":"Buy Access to the ShipGodot iOS repository","anchor":"Buy-Access-to-the-ShipGodot-iOS-repository"},{"type":"step","content":[{"inlineContent":[{"type":"text","text":"Head to "},{"type":"reference","identifier":"https:\/\/shipgodot.com","isActive":true},{"type":"text","text":" and purchase access."}],"type":"paragraph"}],"caption":[],"media":"shipgodot_01.png","runtimePreview":null,"code":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"After a successful purchase, you’ll be redirected to the redeem page. Redeem your license and connect it with your GitHub account to unlock access.","type":"text"}]}],"caption":[],"media":"shipgodot_02.png","runtimePreview":null,"code":null},{"type":"step","content":[{"inlineContent":[{"type":"text","text":"If everything went smoothly, you’ll land on the success page."}],"type":"paragraph"}],"caption":[],"media":"shipgodot_03.png","runtimePreview":null,"code":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Check your email — you should find an invite to the private repository.","type":"text"}]}],"caption":[],"media":"shipgodot_04.png","runtimePreview":null,"code":null}],"contentSection":[{"kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"Before using ShipGodot, you’ll need an Apple Developer account, a GitHub account, and to purchase access to the template. Once set up, you’ll be ready to start building your iOS game."}],"type":"paragraph"}],"media":"account-check.svg","mediaPosition":"trailing"}],"anchor":"Preparing-your-Accounts"},{"title":"Create a Repository for Certificates and Provisioning Profiles","stepsSection":[{"type":"step","content":[{"inlineContent":[{"type":"text","text":"Log in to your GitHub account and navigate to the page for creating a new repository."}],"type":"paragraph"}],"caption":[],"runtimePreview":null,"media":"github-create-certs.png","code":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Give the repository a clear name."},{"type":"text","text":"\n"},{"type":"text","text":"(for example, "},{"inlineContent":[{"text":"apple-developer-certificates","type":"text"}],"type":"strong"},{"type":"text","text":")"}]}],"caption":[],"runtimePreview":null,"media":"github-create-certs-name.png","code":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Set the repository visibility to Private."}]}],"caption":[],"runtimePreview":null,"media":"github-create-certs-visibility.png","code":null},{"type":"step","content":[{"inlineContent":[{"type":"text","text":"Leave the remaining settings at their default values."}],"type":"paragraph"}],"caption":[],"runtimePreview":null,"media":"github-create-certs-rest.png","code":null}],"contentSection":[{"mediaPosition":"trailing","content":[{"inlineContent":[{"type":"text","text":"To use the automated code signing system, you’ll need to create an empty private GitHub repository to store your certificates and provisioning profiles."},{"type":"text","text":" "},{"type":"text","text":"ShipGodot relies on Fastlane Match, which follows the best-practice approach outlined in "},{"type":"reference","identifier":"https:\/\/codesigning.guide","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Once this repository is set up, workflows can access it during the build process without you having to manage the files manually."}],"type":"paragraph"}],"media":"file-sign.svg","kind":"contentAndMedia"}],"anchor":"Create-a-Repository-for-Certificates-and-Provisioning-Profiles"},{"title":"Storing Your Project Credentials","stepsSection":[],"contentSection":[{"media":"lock-check.svg","mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"Each time you set up a new project using ShipGodot iOS, you’ll need to provide several GitHub secrets such as Apple Developer API key,","type":"text"},{"text":" ","type":"text"},{"text":"deploy key for the certificates repository, and other sensitive values.","type":"text"},{"text":" ","type":"text"},{"text":"To keep everything secure and easy to reuse, it’s best to store these credentials in a password manager—","type":"text"},{"identifier":"https:\/\/www.passwordstore.org\/","isActive":true,"type":"reference"},{"text":" works well for this.","type":"text"},{"text":" ","type":"text"},{"text":"Since many of these values will be reused across multiple projects and workflows,","type":"text"},{"text":" ","type":"text"},{"text":"having them safely stored means you can quickly reference and paste them whenever","type":"text"},{"text":" ","type":"text"},{"text":"you initialize a new game project.","type":"text"}]}]}],"anchor":"Storing-Your-Project-Credentials"}]},{"title":"Setting Up Your Reusable Credentials","action":{"identifier":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/reusable-credentials","overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"type":"reference","isActive":true,"overridingTitle":"Get started"},"kind":"callToAction","abstract":[{"text":"In this chapte