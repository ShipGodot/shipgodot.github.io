{"kind":"project","metadata":{"role":"project","categoryPathComponent":"table-of-contents","category":"ShipGodot","title":"Setting Up Your Game Project"},"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[{"chapter":"Project Setup","content":[{"type":"paragraph","inlineContent":[{"text":"In this chapter, we’ll walk through the process of configuring your Godot project for the ShipGodot pipeline,","type":"text"},{"text":" ","type":"text"},{"text":"setting up a deployment repository from the provided template, and connecting the two together.","type":"text"},{"text":" ","type":"text"},{"text":"To guide you through the process, we’ll be using the Multitouch Cubes demo from Godot’s official demo projects as our example.","type":"text"}]}],"kind":"hero","title":"Setting Up Your Game Project"},{"kind":"tasks","tasks":[{"stepsSection":[{"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"In Godot, navigate to ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Project > Project Settings"}]},{"text":" while your project is open.","type":"text"}]}],"code":null,"type":"step","media":"project_config_00.png","runtimePreview":null},{"caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Go to "},{"type":"strong","inlineContent":[{"text":"Rendering > Renderer","type":"text"}]},{"type":"text","text":" and make sure the rendering method is set to at least "},{"type":"strong","inlineContent":[{"type":"text","text":"Mobile"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"text":"gl_compatibility","type":"text"}]},{"type":"text","text":" works poorly on iOS and should be avoided."}]}],"code":null,"type":"step","media":"project_config_01.png","runtimePreview":null},{"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"Go to ","type":"text"},{"inlineContent":[{"text":"Rendering > Textures","type":"text"}],"type":"strong"},{"text":", enable ","type":"text"},{"inlineContent":[{"type":"text","text":"Advanced Settings"}],"type":"strong"},{"text":", and set ","type":"text"},{"inlineContent":[{"type":"text","text":"Import ETC2 ASTC"}],"type":"strong"},{"text":" to true.","type":"text"}]}],"code":null,"type":"step","media":"project_config_02.png","runtimePreview":null},{"caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Go to "},{"inlineContent":[{"type":"text","text":"Application > Config"}],"type":"strong"},{"type":"text","text":" and set a version number using format of three period-separated integers."},{"type":"text","text":" "},{"type":"text","text":"For example 0.0.1. Each number represents "},{"inlineContent":[{"text":"Major","type":"text"}],"type":"strong"},{"type":"text","text":", "},{"inlineContent":[{"text":"Minor","type":"text"}],"type":"strong"},{"type":"text","text":", and "},{"inlineContent":[{"text":"Patch","type":"text"}],"type":"strong"},{"type":"text","text":" respectively."},{"type":"text","text":"\n"},{"inlineContent":[{"text":"Important:","type":"text"}],"type":"strong"},{"type":"text","text":" You’ll need to increment the version number every time you want to upload a new build."}]}],"code":null,"type":"step","media":"project_config_03.png","runtimePreview":null},{"caption":[],"content":[{"inlineContent":[{"text":"Navigate to ","type":"text"},{"inlineContent":[{"text":"Project > Export","type":"text"}],"type":"strong"},{"text":" and add an ","type":"text"},{"inlineContent":[{"text":"iOS","type":"text"}],"type":"strong"},{"text":" export preset.","type":"text"}],"type":"paragraph"}],"code":null,"type":"step","media":"project_config_04.png","runtimePreview":null},{"caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Set "},{"type":"strong","inlineContent":[{"text":"App Store Team ID","type":"text"}]},{"type":"text","text":" to "},{"type":"strong","inlineContent":[{"text":"DO NOT EDIT","type":"text"}]},{"type":"text","text":"."}]}],"code":null,"type":"step","media":"project_config_05.png","runtimePreview":null},{"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"Set ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Provisioning Profile Specifier Release"}]},{"text":" to ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"DO NOT EDIT"}]},{"text":".","type":"text"}]}],"code":null,"type":"step","media":"project_config_06.png","runtimePreview":null},{"caption":[],"content":[{"inlineContent":[{"type":"text","text":"Set "},{"type":"strong","inlineContent":[{"type":"text","text":"Bundle Identifier"}]},{"type":"text","text":" to "},{"type":"strong","inlineContent":[{"text":"DO NOT EDIT","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"Note:"}]},{"type":"text","text":" The "},{"type":"strong","inlineContent":[{"text":"DO NOT EDIT","type":"text"}]},{"type":"text","text":" values will be automatically replaced by the pipeline during the deployment workflow."}],"type":"paragraph"}],"code":null,"type":"step","media":"project_config_07.png","runtimePreview":null},{"caption":[],"content":[{"inlineContent":[{"text":"Set ","type":"text"},{"inlineContent":[{"type":"text","text":"Export Project Only"}],"type":"strong"},{"text":" to true.","type":"text"}],"type":"paragraph"}],"code":null,"type":"step","media":"project_config_08.png","runtimePreview":null}],"contentSection":[{"content":[{"inlineContent":[{"type":"text","text":"You’ll make the necessary changes to your Godot project’s export settings and configuration so it integrates cleanly with ShipGodot’s pipeline."},{"type":"text","text":" "},{"type":"text","text":"By the end, your project will be ready to be built and deployed to the App Store."}],"type":"paragraph"}],"mediaPosition":"trailing","media":"project-edit.svg","kind":"contentAndMedia"}],"title":"Getting Your Godot Project Ready","anchor":"Getting-Your-Godot-P