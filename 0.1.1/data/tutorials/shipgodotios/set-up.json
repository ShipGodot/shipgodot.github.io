\/Beta-Testing","projects":[{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/testflight","sections":[{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/testflight#Creating-Your-App-on-Apple-Platforms","kind":"task"},{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/testflight#Configuring-Repository-Secrets","kind":"task"},{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/testflight#Generating-Certificates-and-Provisioning-Profiles","kind":"task"},{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/testflight#Export-Build-and-Upload-to-TestFlight","kind":"task"}]}]},{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/table-of-contents\/Shipping","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/appstore#Continuous-Deployment-to-TestFlight"},{"kind":"task","reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/appstore#Publishing-to-the-App-Store"},{"kind":"task","reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/appstore#Congratulations"}],"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/appstore"}]}],"reference":"doc:\/\/ShipGodotIOS\/tutorials\/table-of-contents"},"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"role":"project","category":"ShipGodot","title":"Setting Up Your Game Project","categoryPathComponent":"table-of-contents"},"variants":[{"paths":["\/tutorials\/shipgodotios\/set-up"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"project","identifier":{"url":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/set-up","interfaceLanguage":"swift"},"sections":[{"kind":"hero","chapter":"Project Setup","title":"Setting Up Your Game Project","content":[{"inlineContent":[{"type":"text","text":"In this chapter, we’ll walk through the process of configuring your Godot project for the ShipGodot pipeline,"},{"type":"text","text":" "},{"type":"text","text":"setting up a deployment repository from the provided template, and connecting the two together."},{"type":"text","text":" "},{"type":"text","text":"To guide you through the process, we’ll be using the Multitouch Cubes demo from Godot’s official demo projects as our example."}],"type":"paragraph"}]},{"kind":"tasks","tasks":[{"stepsSection":[{"code":null,"content":[{"inlineContent":[{"text":"In Godot, navigate to ","type":"text"},{"inlineContent":[{"type":"text","text":"Project > Project Settings"}],"type":"strong"},{"text":" while your project is open.","type":"text"}],"type":"paragraph"}],"caption":[],"runtimePreview":null,"media":"project_config_00.png","type":"step"},{"code":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Go to "},{"inlineContent":[{"text":"Rendering > Renderer","type":"text"}],"type":"strong"},{"type":"text","text":" and make sure the rendering method is set to at least "},{"inlineContent":[{"type":"text","text":"Mobile"}],"type":"strong"},{"type":"text","text":"."},{"type":"text","text":" "},{"inlineContent":[{"text":"gl_compatibility","type":"text"}],"type":"strong"},{"type":"text","text":" works poorly on iOS and should be avoided."}]}],"caption":[],"runtimePreview":null,"media":"project_config_01.png","type":"step"},{"code":null,"content":[{"inlineContent":[{"type":"text","text":"Go to "},{"type":"strong","inlineContent":[{"type":"text","text":"Rendering > Textures"}]},{"type":"text","text":", enable "},{"type":"strong","inlineContent":[{"text":"Advanced Settings","type":"text"}]},{"type":"text","text":", and set "},{"type":"strong","inlineContent":[{"type":"text","text":"Import ETC2 ASTC"}]},{"type":"text","text":" to true."}],"type":"paragraph"}],"caption":[],"runtimePreview":null,"media":"project_config_02.png","type":"step"},{"code":null,"content":[{"inlineContent":[{"text":"Go to ","type":"text"},{"type":"strong","inlineContent":[{"text":"Application > Config","type":"text"}]},{"text":" and set a version number using format of three period-separated integers.","type":"text"},{"text":" ","type":"text"},{"text":"For example 0.0.1. Each number represents ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Major"}]},{"text":", ","type":"text"},{"type":"strong","inlineContent":[{"text":"Minor","type":"text"}]},{"text":", and ","type":"text"},{"type":"strong","inlineContent":[{"text":"Patch","type":"text"}]},{"text":" respectively.","type":"text"},{"text":"\n","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Important:"}]},{"text":" You’ll need to increment the version number every time you want to upload a new build.","type":"text"}],"type":"paragraph"}],"caption":[],"runtimePreview":null,"media":"project_config_03.png","type":"step"},{"code":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Navigate to "},{"type":"strong","inlineContent":[{"text":"Project > Export","type":"text"}]},{"type":"text","text":" and add an "},{"type":"strong","inlineContent":[{"type":"text","text":"iOS"}]},{"type":"text","text":" export preset."}]}],"caption":[],"runtimePreview":null,"media":"project_config_04.png","type":"step"},{"code":null,"content":[{"inlineContent":[{"text":"Set ","type":"text"},{"inlineContent":[{"type":"text","text":"App Store Team ID"}],"type":"strong"},{"text":" to ","type":"text"},{"inlineContent":[{"type":"text","text":"DO NOT EDIT"}],"type":"strong"},{"text":".","type":"text"}],"type":"paragraph"}],"caption":[],"runtimePreview":null,"media":"project_config_05.png","type":"step"},{"code":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Set ","type":"text"},{"type":"strong","inlineContent":[{"text":"Provisioning Profile Specifier Release","type":"text"}]},{"text":" to ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"DO NOT EDIT"}]},{"text":".","type":"text"}]}],"caption":[],"runtimePreview":null,"media":"project_config_06.png","type":"step"},{"code":null,"content":[{"inlineContent":[{"type":"text","text":"Set "},{"type":"strong","inlineContent":[{"type":"text","text":"Bundle Identifier"}]},{"type":"text","text":" to "},{"type":"strong","inlineContent":[{"type":"text","text":"DO NOT EDIT"}]},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"Note:"}]},{"type":"text","text":" The "},{"type":"strong","inlineContent":[{"type":"text","text":"DO NOT EDIT"}]},{"type":"text","text":" values will be automatically replaced by the pipeline during the deployment workflow."}],"type":"paragraph"}],"caption":[],"runtimePreview":null,"media":"project_config_07.png","type":"step"},{"code":null,"content":[{"inlineContent":[{"type":"text","text":"Set "},{"type":"strong","inlineContent":[{"type":"text","text":"Export Project Only"}]},{"type":"text","text":" to true."}],"type":"paragraph"}],"caption":[],"runtimePreview":null,"media":"project_config_08.png","type":"step"}],"title":"Getting Your Godot Project Ready","contentSection":[{"mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"text":"You’ll make the necessary changes to your Godot project’s export settings and configuration so it integrates cleanly with ShipGodot’s pipeline.","type":"text"},{"text":" ","type":"text"},{"text":"By the end, your project will be ready to be built and deployed to the App Store.","type":"text"}]}],"media":"project-edit.svg","kind":"contentAndMedia"}],"anchor":"Getting-Your-Godot-Project-Ready"},{"stepsSection":[{"type":"step","media":"using_template_00.png","content":[{"inlineContent":[{"type":"text","text":"Navigate to shipgodot-ios repository on GitHub — the one you were invited to (subscription) or set up yourself (Snapshot)."}],"type":"paragraph"}],"caption":[],"code":null,"runtimePreview":null},{"type":"step","media":"using_template_01.png","content":[{"inlineContent":[{"type":"text","text":"Click the "},{"type":"strong","inlineContent":[{"type":"text","text":"Use this template"}]},{"type":"text","text":" button in the repository header and select "},{"type":"strong","inlineContent":[{"text":"Create a new repository","type":"text"}]},{"type":"text","text":" from the dropdown."}],"type":"paragraph"}],"caption":[],"code":null,"runtimePreview":null},{"type":"step","media":"using_template_02.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Enter a name for your repository — a good convention is your game’s name followed by a ‘-deploy’ suffix."}]}],"caption":[],"code":null,"runtimePreview":null},{"type":"step","media":"using_template_03.png","content":[{"type":"paragraph","inlineContent":[{"text":"Add a description or leave it empty.","type":"text"}]}],"caption":[],"code":null,"runtimePreview":null},{"type":"step","media":"using_template_04.png","content":[{"type":"paragraph","inlineContent":[{"text":"Set the repository visibility to ","type":"text"},{"inlineContent":[{"type":"text","text":"Private"}],"type":"strong"},{"text":".","type":"text"},{"text":"\n","type":"text"},{"inlineContent":[{"text":"Note:","type":"text"}],"type":"strong"},{"text":" The license requires that repositories created from this template remain ","type":"text"},{"inlineContent":[{"text":"Private","type":"text"}],"type":"strong"},{"text":".","type":"text"}]}],"caption":[],"code":null,"runtimePreview":null},{"type":"step","media":"using_template_05.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Click "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Create repository"}]},{"type":"text","text":" and wait for it to be generated."}]}],"caption":[],"code":null,"runtimePreview":null},{"type":"step","media":"using_template_06.png","content":[{"inlineContent":[{"type":"text","text":"Your deployment repository is set up."}],"type":"paragraph"}],"caption":[],"code":null,"runtimePreview":null}],"title":"Setting Up the Deployment Repository","contentSection":[{"media":"source-repository-multiple.svg","mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"In this section, you’ll create your own deployment repository from the shipgodot-ios template.","type":"text"},{"text":" ","type":"text"},{"text":"This repository will hold all the scripts and configuration needed to automatically build and deploy your game.","type":"text"}]}]}],"anchor":"Setting-Up-the-Deployment-Repository"},{"stepsSection":[{"code":null,"type":"step","caption":[],"content":[{"inlineContent":[{"type":"text","text":"In the deployment repository, locate the game directory."},{"type":"text","text":" "},{"type":"text","text":"This is where your Godot project files need to live, with game acting as the root directory of your project."}],"type":"paragraph"}],"runtimePreview":null,"media":"connect_project_0.png"},{"code":null,"type":"step","caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"If you’re not familiar with Git, the easiest way is to drag and drop your project files directly into the game directory on GitHub,","type":"text"},{"text":" ","type":"text"},{"text":"then commit the changes.","type":"text"}]}],"runtimePreview":null,"media":"connect_project_00.png"},{"code":null,"type":"step","caption":[],"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Note:"}],"type":"strong"},{"text":" If you’re adding your files by dragging and dropping, or directly via Git, you can skip the rest of this section.","type":"text"}],"type":"paragraph"}],"runtimePreview":null,"media":"connect_project_01.png"},{"code":null,"type":"step","caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"The recommended approach is to keep your project files in a separate repository and link it to the deployment repository as a Git submodule.","type":"text"}]}],"runtimePreview":null,"media":"connect_project_02.png"},{"code":"connect_project_03.sh","type":"step","caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"Start by deleting the game directory from the deployment repository.","type":"text"}]}],"runtimePreview":null,"media":null},{"code":"connect_project_04.sh","type":"step","caption":[],"content":[{"inlineContent":[{"type":"text","text":"Add your project repository as a submodule using the following command,"},{"type":"text","text":" "},{"type":"text","text":"replacing the link with the one pointing to your own repository:"}],"type":"paragraph"}],"runtimePreview":null,"media":null},{"code":"connect_project_04b.sh","type":"step","caption":[],"content":[{"inlineContent":[{"text":"Commit and push the changes to your deployment repository.","type":"text"}],"type":"paragraph"}],"runtimePreview":null,"media":null},{"code":null,"type":"step","caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"Generate a SSH deploy key for your game repository as shown in ","type":"text"},{"identifier":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/reusable-credentials#GitHub-Certificates-Repository-Credentials","type":"reference","overridingTitle":"Reusable Credentials","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"Reusable Credentials"}]},{"text":".","type":"text"}]}],"runtimePreview":null,"media":"connect_project_05.png"},{"code":null,"type":"step","caption":[],"content":[{"inlineContent":[{"text":"Navigate to ⚙️ ","type":"text"},{"inlineContent":[{"type":"text","text":"Settings"}],"type":"strong"},{"text":" in your game repository and select ","type":"text"},{"inlineContent":[{"type":"text","text":"Deploy Keys"}],"type":"strong"},{"text":".","type":"text"}],"type":"paragraph"}],"runtimePreview":null,"media":"connect_project_06.png"},{"code":null,"type":"step","caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Provide a title for the key, then paste the generated public key (the file ending in .pub) into the Key field."}]}],"runtimePreview":null,"media":"connect_project_08.png"},{"code":null,"type":"step","caption":[],"content":[{"inlineContent":[{"text":"Save the private key in your password manager as ","type":"text"},{"type":"strong","inlineContent":[{"text":"GAME_REPO_KEY","type":"text"}]},{"text":".","type":"text"}],"type":"paragraph"}],"runtimePreview":null,"media":"connect_project_08.png"}],"title":"Connecting Your Project to the Deployment Repository","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"inlineContent":[{"text":"In this section, you’ll add your Godot project files to the deployment repository.","type":"text"},{"text":" ","type":"text"},{"text":"You can either add them directly or link your existing project repository as a submodule — whichever works best for you.","type":"text"}],"type":"paragraph"}],"media":"connection.svg"}],"anchor":"Connecting-Your-Project-to-the-Deployment-Repository"}]},{"kind":"callToAction","action":{"overridingTitle":"Get started","overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"identifier":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/testflight","isActive":true,"type":"reference"},"featuredEyebrow":"Tutorial","title":"Beta Testing with TestFlight","abstract":[{"text":"In this chapter, you’ll go through everything needed to get your first build live on TestFlight.","type":"text"},{"text":" ","type":"text"},{"text":"You’ll create your app on App Store Connect, configure all the required secrets in your deployment repository,","type":"text"},{"text":" ","type":"text"},{"text":"generate the necessary certificates and provisioning profiles, and finally trigger the pipeline to build and upload your game automatically.","type":"text"}]}],"references":{"project_config_01.png":{"alt":"Godot - Rendering > Renderer settings","type":"image","identifier":"project_config_01.png","variants":[{"traits":["1x","light"],"url":"\/images\/ShipGodotIOS\/project_config_01.png"}]},"doc://ShipGodotIOS/tutorials/table-of-contents":{"type":"topic","url":"\/tutorials\/table-of-contents","identifier":"doc:\/\/ShipGodotIOS\/tutorials\/table-of-contents","role":"overview","kind":"ov