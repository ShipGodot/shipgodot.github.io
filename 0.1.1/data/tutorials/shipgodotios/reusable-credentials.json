{"identifier":{"url":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/reusable-credentials","interfaceLanguage":"swift"},"kind":"project","sections":[{"chapter":"Credentials","content":[{"inlineContent":[{"text":"In this chapter, you’ll gather and securely store various secrets—like API keys and deploy keys—that will be reused across all future projects using ShipGodot iOS.","type":"text"}],"type":"paragraph"}],"title":"Setting Up Your Reusable Credentials","kind":"hero"},{"kind":"tasks","tasks":[{"contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"You’ll need several important credentials from the Apple Developer portal to enable automated signing and publishing.","type":"text"},{"text":" ","type":"text"},{"text":"These values uniquely identify your development team and allow the build workflows to authenticate with Apple on your behalf.","type":"text"},{"text":" ","type":"text"},{"text":"In the next steps, we’ll walk through where to find each of these credentials.","type":"text"},{"text":"\n","type":"text"},{"inlineContent":[{"type":"text","text":"Remember to store them safely"}],"type":"strong"},{"text":" so they can be reused across future projects.","type":"text"}]}],"mediaPosition":"trailing","kind":"contentAndMedia","media":"apple.svg"}],"title":"Apple Developer Credentials","stepsSection":[{"type":"heading","level":3,"text":"APPLE_TEAM_ID","anchor":"APPLETEAMID"},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open your "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/account"},{"type":"text","text":" dashboard."}]}],"runtimePreview":null,"caption":[],"media":"apple-step01.png","code":null},{"type":"step","content":[{"inlineContent":[{"type":"text","text":"Navigate to the "},{"inlineContent":[{"text":"Certificates","type":"text"}],"type":"strong"},{"type":"text","text":" section within "},{"inlineContent":[{"type":"text","text":"Certificates, IDs & Profiles"}],"type":"strong"},{"type":"text","text":"."}],"type":"paragraph"}],"runtimePreview":null,"caption":[],"media":"apple-step02.png","code":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"You’ll find your ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/help\/glossary\/team-id\/"},{"text":" displayed in the upper-right corner of the page.","type":"text"}]}],"runtimePreview":null,"caption":[],"media":"apple-step03.png","code":null},{"type":"step","content":[{"inlineContent":[{"type":"text","text":"Save it in your password manager of choice as "},{"type":"strong","inlineContent":[{"type":"text","text":"APPLE_TEAM_ID"}]},{"type":"text","text":", keeping the name consistent since this value will be referenced later in the tutorial along with other secrets."}],"type":"paragraph"}],"runtimePreview":null,"caption":[],"media":"apple-step04.png","code":null},{"type":"heading","level":3,"text":"APPLE_API_KEY \/ APPLE_API_KEY_ID \/ APPLE_API_ISSUER_ID","anchor":"APPLEAPIKEY--APPLEAPIKEYID--APPLEAPIISSUERID"},{"type":"step","content":[{"inlineContent":[{"type":"text","text":"Go back to your "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/account"},{"type":"text","text":" and navigate to the "},{"type":"strong","inlineContent":[{"text":"Users and Access","type":"text"}]},{"type":"text","text":" section within "},{"type":"strong","inlineContent":[{"text":"App Store Connect","type":"text"}]},{"type":"text","text":"."}],"type":"paragraph"}],"runtimePreview":null,"caption":[],"media":"apple-step05.png","code":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"In ","type":"text"},{"inlineContent":[{"text":"Users and Access","type":"text"}],"type":"strong"},{"text":", switch to the ","type":"text"},{"inlineContent":[{"type":"text","text":"Integrations"}],"type":"strong"},{"text":" tab using the top menu.","type":"text"}]}],"runtimePreview":null,"captio