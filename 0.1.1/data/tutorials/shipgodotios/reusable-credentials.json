":null,"caption":[],"media":null,"code":"apple-step12.p8"},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Keep the ","type":"text"},{"type":"strong","inlineContent":[{"text":"—–BEGIN PRIVATE KEY—–","type":"text"}]},{"text":" and ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"—–END PRIVATE KEY—–"}]},{"text":" markers intact.","type":"text"}]}],"runtimePreview":null,"caption":[],"media":null,"code":"apple-step12e.p8"},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Add ","type":"text"},{"inlineContent":[{"type":"text","text":"\\n"}],"type":"strong"},{"text":" immediately after ","type":"text"},{"inlineContent":[{"text":"—–BEGIN PRIVATE KEY—–","type":"text"}],"type":"strong"},{"text":".","type":"text"}]}],"runtimePreview":null,"caption":[],"media":null,"code":"apple-step13.p8"},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Add ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"\\n"}]},{"text":" immediately before ","type":"text"},{"type":"strong","inlineContent":[{"text":"—–END PRIVATE KEY—–","type":"text"}]},{"text":".","type":"text"}]}],"runtimePreview":null,"caption":[],"media":null,"code":"apple-step14.p8"},{"type":"step","content":[{"inlineContent":[{"text":"Remove all line breaks so the key becomes one continuous string.","type":"text"}],"type":"paragraph"}],"runtimePreview":null,"caption":[],"media":null,"code":"apple-step15.p8"},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Verify that your key matches the format shown in the example.","type":"text"}]}],"runtimePreview":null,"caption":[],"media":null,"code":"apple-step15.p8"},{"type":"step","content":[{"inlineContent":[{"type":"text","text":"Save the edited API key in your password manager as "},{"type":"strong","inlineContent":[{"type":"text","text":"APPLE_API_KEY"}]},{"type":"text","text":"."},{"type":"text","text":"\n"},{"type":"text","text":"Once saved, delete the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"AuthKey_XXXXXXXXXX.p8"}]},{"type":"text","text":" file from your file system to keep it secure."}],"type":"paragraph"}],"runtimePreview":null,"caption":[],"media":"password-60.svg","code":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Before moving on, save the email address you use to log in to the Apple Developer Portal as "},{"inlineContent":[{"text":"APPLE_DEVELOPER_EMAIL","type":"text"}],"type":"strong"},{"type":"text","text":" in your password manager."},{"type":"text","text":" "},{"type":"text","text":"This way, all the credentials you’ll need when setting up a new project will be in one place."}]}],"runtimePreview":null,"caption":[],"media":"password-60.svg","code":null}],"anchor":"Apple-Developer-Credentials"},{"stepsSection":[{"level":3,"text":"CERT_REPO_KEY","anchor":"CERTREPOKEY","type":"heading"},{"caption":[],"media":"github-step01.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"First, you’ll need to generate an SSH key pair."},{"type":"text","text":" "},{"type":"text","text":"Follow "},{"type":"reference","identifier":"https:\/\/docs.github.com\/en\/authentication\/connecting-to-github-with-ssh\/generating-a-new-ssh-key-and-adding-it-to-the-ssh-agent#generating-a-new-ssh-key","isActive":true},{"type":"text","text":" for your platform to create one."},{"type":"text","text":"\n"},{"type":"strong","inlineContent":[{"text":"Note","type":"text"}]},{"type":"text","text":": When you reach the step that prompts you for a passphrase, "},{"type":"strong","inlineContent":[{"text":"leave it empty","type":"text"}]},{"type":"text","text":". The CI workflows won’t be able to use a password-protected key."}]}],"code":null,"runtimePreview":null,"type":"step"},{"caption":[],"media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Copy the contents of the private key file and save it in your password manager as "},{"type":"strong","inlineContent":[{"type":"text","text":"CERT_REPO_KEY"}]},{"type":"text","text":"."},{"type":"text","text":"\n"},{"type":"text","text":"Once saved, delete the private key file from your file system to keep it secure."}]}],"code":"cert_repo01.txt","runtimePreview":null,"type":"step"},{"caption":[],"media":"github-step02.png","content":[{"inlineContent":[{"type":"text","text":"On GitHub, navigate to the main page of the certificates repository."}],"type":"paragraph"}],"code":null,"runtimePreview":null,"type":"step"},{"caption":[],"media":"github-step03.png","content":[{"inlineContent":[{"text":"Under your repository name, click ⚙️Settings. If you cannot see the “Settings” tab, select the dropdown menu, then click Settings.","type":"text"}],"type":"paragraph"}],"code":null,"runtimePreview":null,"type":"step"},{"caption":[],"media":"github-step04.png","content":[{"inlineContent":[{"text":"In the sidebar, click Deploy Keys.","type":"text"}],"type":"paragraph"}],"code":null,"runtimePreview":null,"type":"step"},{"caption":[],"media":"github-step05.png","content":[{"inlineContent":[{"type":"text","text":"Click Add deploy key"}],"type":"paragraph"}],"code":null,"runtimePreview":null,"type":"step"},{"caption":[],"media":"github-step06.png","content":[{"type":"paragraph","inlineContent":[{"text":"In the “Title” field, provide a title. (eg. “Godot Template Workflows”)","type":"text"}]}],"code":null,"runtimePreview":null,"type":"step"},{"caption":[],"media":"github-step07.png","content":[{"inlineContent":[{"type":"text","text":"In the “Key” field, paste the contents of your generated public key file (the one ending in "},{"type":"codeVoice","code":".pub"},{"type":"text","text":")."}],"type":"paragraph"}],"code":null,"runtimePreview":null,"type":"step"},{"caption":[],"media":"github-step08.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Select "},{"type":"strong","inlineContent":[{"text":"Allow write access","type":"text"}]},{"type":"text","text":"."}]}],"code":null,"runtimePreview":null,"type":"step"},{"caption":[],"media":"github-step09.png","content":[{"inlineContent":[{"type":"text","text":"Click Add key."}],"type":"paragraph"}],"code":null,"runtimePreview":null,"type":"step"},{"level":3,"text":"CERT_REPO_PASSWORD \/ CERT_REPO_URL","anchor":"CERTREPOPASSWORD--CERTREPOURL","type":"heading"},{"caption":[],"media":"github-step10.png","content":[{"inlineContent":[{"type":"text","text":"Save your certificates repository URL as "},{"type":"strong","inlineContent":[{"type":"text","text":"CERT_REPO_URL"}]},{"type":"text","text":" in your password manager. You can find the URL on the repository’s main page."},{"type":"text","text":"\n"},{"type":"strong","inlineContent":[{"type":"text","text":"Note"}]},{"type":"text","text":": Make sure to use the SSH URL (starting with "},{"type":"emphasis","inlineContent":[{"type":"text","text":"git@github.com:"}]},{"type":"text","text":")"}],"type":"paragraph"}],"code":null,"runtimePreview":null,"type":"step"},{"caption":[],"media":"password-60.svg","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Finally, you’ll need to create an encryption password to protect your certificates and provisioning profiles."},{"type":"text","text":" "},{"type":"text","text":"We recommend using your password manager to generate a strong, random password and save it as "},{"type":"strong","inlineContent":[{"type":"text","text":"CERT_REPO_PASSWORD"}]},{"type":"text","text":"."}]}],"code":null,"runtimePreview":null,"type":"step"}],"contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Before the CI workflows can build and publish your game to the App Store, they need access to your ","type":"text"},{"identifier":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/getting-started#Create-a-Repository-for-Certificates-and-Provisioning-Profiles","overridingTitle":"certificates repository","isActive":true,"type":"reference","overridingTitleInlineContent":[{"type":"text","text":"certificates repository"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"In this section, we’ll create a GitHub deploy key that allows the workflows to read and update your certificates and provisioning profiles.","type":"text"}]}],"kind":"contentAndMedia","mediaPosition":"trailing","media":"github.svg"}],"title":"GitHub Certificates Repository Credentials","anchor":"GitHub-Certificates-Repository-Credentials"},{"stepsSection":[],"contentSection":[{"media":"password-60.svg","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"By the end of this section, your password manager should contain the following values,"},{"type":"text","text":" "},{"type":"text","text":"ready to be copied into your repository secrets whenever you set up a new project."},{"type":"text","text":" "},{"type":"text","text":"While not all of these are strictly credentials, keeping them together in your password manager makes setup quick and convenient:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"APPLE_API_KEY"}]},{"text":" – Your App Store Connect API private key","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"APPLE_API_ISSUER_ID","type":"text"}]},{"type":"text","text":" – The issuer ID associated with your API key"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"APPLE_API_KEY_ID"}]},{"text":" – The key ID for your API key","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"APPLE_TEAM_ID","type":"text"}]},{"type":"text","text":" – Your Apple Developer team identifier"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"APPLE_DEVELOPER_EMAIL","type":"text"}]},{"type":"text","text":" – The email address associated with your Apple Developer account"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"CERT_REPO_KEY","type":"text"}]},{"type":"text","text":" – The private SSH key for accessing your certificates repository"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"CERT_REPO_URL"}]},{"type":"text","text":" – The URL of your certificates repository"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"CERT_REPO_PASSWORD","type":"text"}],"type":"strong"},{"type":"text","text":" – The encryption password for your certificates and provisioning profiles"}]}]}]}],"kind":"contentAndMedia","mediaPosition":"trailing"}],"title":"Credentials Checklist","anchor":"Credentials-Checklist"}]},{"abstract":[{"type":"text","text":"In this chapter, we’ll walk through the process of configuring your Godot project for the ShipGodot pipeline,"},{"type":"text","text":" "},{"type":"text","text":"setting up a deployment repository from the provided template, and connecting the two together."},{"type":"text","text":" "},{"type":"text","text":"To guide you through the process, we’ll be using the Multitouch Cubes demo from Godot’s official demo projects as our example."}],"kind":"callToAction","featuredEyebrow":"Tutorial","title":"Setting Up Your Game Project","action":{"type":"reference","overridingTitle":"Get started","overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"isActive":true,"identifier":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/set-up"}}],"hierarchy":{"modules":[{"projects":[{"reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/getting-started","sections":[{"kind":"task","reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/getting-started#Preparing-your-Accounts"},{"kind":"task","reference":"doc:\/\/ShipGodotIOS\/tutorials\/ShipGodotIOS\/getting-started#Create-a-Repository-for-Certificates-and-Provisioning-Pro