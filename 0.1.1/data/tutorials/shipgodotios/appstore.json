{"kind":"project","sections":[{"chapter":"Shipping","content":[{"inlineContent":[{"type":"text","text":"In this chapter, you’ll go through the full cycle of deploying updates to your testers, and when the time feels right, publishing your game to the App Store for the world to play."}],"type":"paragraph"}],"title":"Shipping Your Game to the App Store","kind":"hero"},{"tasks":[{"anchor":"Continuous-Deployment-to-TestFlight","title":"Continuous Deployment to TestFlight","contentSection":[{"kind":"contentAndMedia","media":"airplane-edit.svg","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In this section, you’ll go through the full cycle of making a change to your game and deploying it to TestFlight."},{"type":"text","text":" "},{"type":"text","text":"From this point on, this is all it takes to get a new build in front of your testers."}]}]}],"stepsSection":[{"caption":[],"media":"cd_00.png","code":null,"runtimePreview":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"For the sake of this tutorial, let’s make a small change to the Multitouch Cubes demo by modifying the background color."}],"type":"paragraph"}]},{"caption":[],"media":"cd_01.png","code":null,"runtimePreview":null,"type":"step","content":[{"inlineContent":[{"text":"Before anything else, increment the version number in ","type":"text"},{"inlineContent":[{"text":"Project > Project Settings > Application > Config","type":"text"}],"type":"strong"},{"type":"text","text":""},{"type":"text","text":"\n"},{"type":"text","text":"— every new build uploaded to TestFlight must have a higher version number than the previous one."}],"type":"paragraph"}]},{"code":null,"media":"cd_02.png","caption":[],"runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"If you’re using drag and drop, upload the changed files directly to the game directory on GitHub."}],"type":"paragraph"}],"type":"step"},{"code":"cd_03.sh","media":null,"caption":[],"runtimePreview":null,"content":[{"inlineContent":[{"text":"If you’re using submodules, make sure to update the submodule reference in the deployment repository to point to the new commit.","type":"text"}],"type":"paragraph"}],"type":"step"},{"code":null,"media":"cd_04.png","caption":[],"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open your deployment repository on GitHub and navigate to "},{"type":"strong","inlineContent":[{"text":"Actions","type":"text"}]},{"type":"text","text":"."}]}],"type":"step"},{"code":null,"media":"cd_06.png","caption":[],"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Select the "},{"type":"strong","inlineContent":[{"type":"text","text":"Distribute to TestFlight"}]},{"type":"text","text":" workflow from the "},{"type":"strong","inlineContent":[{"type":"text","text":"All Workflows"}]},{"type":"text","text":" menu."}]}],"type":"step"},{"code":null,"media":"cd_07.png","caption":[],"runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"Select the Godot version you are using, then click "},{"type":"strong","inlineContent":[{"text":"Run Workflow","type":"text"}]},{"type":"text","text":"."},{"type":"text","text":"\n"},{"type":"strong","inlineContent":[{"type":"text","text":"Note:"}]},{"type":"text","text":" Only stable Godot releases are supported."}],"type":"paragraph"}],"type":"step"},{"code":null,"media":"cd_08.png","caption":[],"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Wait for all jobs to complete."}]}],"type":"step"},{"code":null,"media":"cd_09.png","caption":[],"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The updated build should appear in the TestFlight app shortly after."}]}],"type":"step"}]},{"title":"Publishing to the App Store","anchor":"Publishing-to-the-App-Store","contentSection":[{"mediaPosition":"trailing","content":[{"inlineContent":[{"type":"text","text":"When your testing is complete and you have a build on TestFlight that you’re happy with, publishing it to the App Store is just a few steps away."}],"type":"paragraph"}],"kind":"contentAndMedia","media":"cash.svg"}],"stepsSection":[{"type":"step","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Head to your app page on App Store Connect."}]}],"caption":[],"media":"appstore_00.png","code":null},{"type":"step","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Scroll down to click ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Add Build"}]},{"text":".","type":"text"}]}],"caption":[],"media":"appstore_01.png","code":null},{"type":"step","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Select the build you are satisfied with from your TestFlight builds.","type":"text"}]}],"caption":[],"media":"appstore_02.png","code":null},{"type":"step","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Fill in all the required screenshots and descriptions, then click "},{"type":"strong","inlineContent":[{"text":"Add for Review","type":"text"}]},{"type":"text","text":" when your page feels ready."},{"type":"text","text":"\n"},{"type":"strong","inlineContent":[{"type":"text","text":"Note:"}]},{"type":"text","text":" The App Store review process can take up to a week."}]}],"caption":[],"media":"appstore_03.png","code":null}]},{"title":"Congratulations!","anchor":"Congratulations","contentSection":[{"media":"rocket.svg","mediaPosition":"trailing","kind":"contentAndMedia","content":[{"inlineContent":[{"text":"Thank you for using ShipGodot — your game is now live on the App Store! We hope it’s the first of many. Good luck with your future projects, and happy shipping!","type":"text"}],"type":"paragraph"}]}],"stepsSection":[]}],"kind":"tasks"}],"hierarchy":{"modules":[{"projects":[{"sec