ext":"After purchasing a subscription, you’ll be redirected to the redeem page. Redeem your license and connect it with your GitHub account to unlock repository access.","type":"text"}],"type":"paragraph"}],"media":"shipgodot_02.png","caption":[]},{"code":null,"type":"step","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"If everything went smoothly, you’ll land on the success page.","type":"text"}]}],"media":"shipgodot_03.png","caption":[]},{"code":null,"type":"step","runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"Check your email — you should find an invite to the private repository."}],"type":"paragraph"}],"media":"shipgodot_04.png","caption":[]}],"anchor":"Preparing-your-Accounts","title":"Preparing your Accounts"},{"contentSection":[{"media":"file-sign.svg","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"To use the automated code signing system, you’ll need to create an empty private GitHub repository to store your certificates and provisioning profiles.","type":"text"},{"text":" ","type":"text"},{"text":"ShipGodot relies on Fastlane Match, which follows the best-practice approach outlined in ","type":"text"},{"identifier":"https:\/\/codesigning.guide","isActive":true,"type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Once this repository is set up, workflows can access it during the build process without you having to manage the files manually.","type":"text"}]}],"mediaPosition":"trailing"}],"stepsSection":[{"code":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Log in to your GitHub account and navigate to the page for creating a new repository."}]}],"media":"github-create-certs.png","runtimePreview":null,"caption":[]},{"code":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Give the repository a clear name."},{"type":"text","text":"\n"},{"type":"text","text":"(for example, "},{"type":"strong","inlineContent":[{"type":"text","text":"apple-developer-certificates"}]},{"type":"text","text":")"}]}],"media":"github-create-certs-name.png","runtimePreview":null,"caption":[]},{"code":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Set the repository visibility to Private."}]}],"media":"github-create-certs-visibility.png","runtimePreview":null,"caption":[]},{"code":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"Leave the remaining settings at their default values."}],"type":"paragraph"}],"media":"github-create-certs-rest.png","runtimePreview":null,"caption":[]}],"anchor":"Create-a-Repository-for-Certificates-and-Provisioning-Profiles","title":"Create a Repository for Certificates and Provisioning Profiles"},{"contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Each time you set up a new project using ShipGodot iOS, you’ll need to provide several GitHub secrets such as Apple Developer API key,"},{"type":"text","text":" "},{"type":"text","text":"deploy key for the certificates repository, and other sensitive values."},{"type":"text","text":" "},{"type":"text","text":"To keep everything secure and easy to reuse, it’s best to store these credentials in a password manager—"},{"type":"reference","isActive":true,"identifier":"https:\/\/www.passwordstore.org\/"},{"type":"text","text":" works well for this."},{"type":"text","text":" "},{"type":"text","text":"Since many of these values will be reused across multiple projects and workflows,"},{"type":"text","text":" "},{"type":"text","text":"having them safely stored means you can quickly reference and paste them whenever"},{"type":"text","text":" "},{"type":"text","text":"you initialize a new game project."}]}],"mediaPosition":"trailing","kind":"contentAndMedia","media":"lock-check.svg"}],"stepsSection":[],"anchor":"Storing-Your-Project-Credentials","title":"Storing Your Project Credent